---
const { name, description, url, icon } = Astro.props;
---
<a href={url} target="_blank" class="flex items-center gap-4 p-4 rounded-2xl bg-transparent hover:bg-black/5 dark:hover:bg-white/5 hover:shadow-md border border-transparent hover:border-gray-200 dark:hover:border-gray-700 transition-all duration-300 cursor-pointer no-underline group w-full">
  <div class="w-14 h-14 flex-shrink-0 bg-gray-50 dark:bg-gray-800/80 rounded-xl flex items-center justify-center p-2">
    <img src={icon} alt={name} class="w-full h-full object-contain" />
  </div>
  <div class="flex flex-col flex-1 min-w-0">
    <span class="font-bold text-gray-900 dark:text-gray-100 text-base truncate m-0 leading-tight">{name}</span>
    <span class="text-sm text-gray-500 dark:text-gray-400 truncate mt-1 m-0 leading-tight">{description}</span>
  </div>
</a>